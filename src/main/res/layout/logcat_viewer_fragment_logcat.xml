<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:id="@+id/root"
    tools:context=".LogcatActivity"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?actionBarSize"
        app:navigationIcon="?attr/homeAsUpIndicator"
        app:title=""
        app:menu="@menu/logcat"
        >

        <Spinner
            android:id="@+id/spinner"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            tools:listitem="@layout/logcat_viewer_item_logcat_dropdown"
            />

    </androidx.appcompat.widget.Toolbar>

    <ListView
        android:id="@+id/list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        tools:listitem="@layout/logcat_viewer_item_logcat"
        android:clipToPadding="false"
        />

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/filter_input_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="16dp"
        android:paddingVertical="8dp"
        app:startIconDrawable="@drawable/logcat_ic_baseline_search_24"
        app:endIconMode="clear_text"
        app:hintEnabled="true"
        app:hintAnimationEnabled="true">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/filter_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/logcat_viewer_search_hint"
            android:inputType="text"
            android:maxLines="1"
            android:imeOptions="actionSearch" />

    </com.google.android.material.textfield.TextInputLayout>

</LinearLayout>